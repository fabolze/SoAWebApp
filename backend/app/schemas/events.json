{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID for the event",
      "ui": {
        "widget": "hidden"
      }
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Stable identifier used to reference this event from timelines, quests, and scripts."
    },
    "title": {
      "type": "string",
      "description": "Internal title for the event",
      "ui": {
        "widget": "text",
        "label": "Title"
      }
    },
    "type": {
      "type": "string",
      "description": "Type of event logic",
      "enum": [
        "Encounter",
        "ItemReward",
        "LoreDiscovery",
        "Dialogue",
        "Teleport",
        "ScriptedScene"
      ],
      "ui": {
        "widget": "select",
        "label": "Event Type",
        "options": [
          "Encounter",
          "ItemReward",
          "LoreDiscovery",
          "Dialogue",
          "Teleport",
          "ScriptedScene"
        ]
      }
    },
    "requirements_id": {
      "type": "string",
      "description": "Requirement to unlock this event",
      "ui": {
        "widget": "reference",
        "reference": "requirements",
        "label": "Requirements"
      }
    },
    "location_id": {
      "type": "string",
      "description": "Optional: location where this event occurs",
      "ui": {
        "widget": "reference",
        "reference": "locations",
        "label": "Location"
      }
    },
    "lore_id": {
      "type": "string",
      "description": "Required if type = LoreDiscovery",
      "ui": {
        "widget": "reference",
        "reference": "lore-entries",
        "label": "Lore Entry"
      }
    },
    "dialogue_id": {
      "type": "string",
      "description": "Required if type = Dialogue",
      "ui": {
        "widget": "reference",
        "reference": "dialogues",
        "label": "Dialogue"
      }
    },
    "encounter_id": {
      "type": "string",
      "description": "Required if type = Encounter",
      "ui": {
        "widget": "reference",
        "reference": "encounters",
        "label": "Encounter"
      }
    },
    "item_rewards": {
      "type": "array",
      "description": "If type = ItemReward, the items given",
      "items": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "items",
              "label": "Item"
            },
            "description": "Item granted when this event resolves."
          },
          "quantity": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Quantity"
            },
            "description": "Number of copies of the selected item awarded."
          }
        },
        "required": [
          "item_id",
          "quantity"
        ]
      }
    },
    "xp_reward": {
      "type": "number",
      "description": "XP granted after completing the event",
      "ui": {
        "widget": "number",
        "label": "Experience"
      }
    },
    "currency_rewards": {
      "type": "array",
      "description": "Currencies granted when the event resolves",
      "items": {
        "type": "object",
        "properties": {
          "currency_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "currencies",
              "label": "Currency"
            },
            "description": "Currency granted when this event resolves."
          },
          "amount": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Amount"
            },
            "description": "Amount of the selected currency awarded."
          }
        },
        "required": [
          "currency_id",
          "amount"
        ]
      }
    },
    "reputation_rewards": {
      "type": "array",
      "description": "Faction reputation adjustments applied",
      "items": {
        "type": "object",
        "properties": {
          "faction_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "factions",
              "label": "Faction"
            },
            "description": "Faction whose reputation changes when this event resolves."
          },
          "amount": {
            "type": "number",
            "description": "Positive or negative reputation delta",
            "ui": {
              "widget": "number",
              "label": "Delta"
            }
          }
        },
        "required": [
          "faction_id",
          "amount"
        ]
      }
    },
    "actions": {
      "type": "array",
      "description": "Ordered typed gameplay and quest actions. Web/export validated; each row declares runtime support separately.",
      "ui": { "widget": "array", "label": "Gameplay Actions" },
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Stable action/replay identity." },
          "action_type": { "type": "string", "enum": ["apply_effect", "restore_resource", "apply_status", "remove_status", "remove_matching_statuses", "grant_currency", "take_currency", "discover_quest", "assign_quest", "reveal_map_marker", "turn_in_quest", "track_inventory_objective", "join_companion", "set_party_membership", "activate_location_variant", "activate_character_variant", "activate_item_variant"] },
          "target_scope": { "type": "string", "enum": ["player", "party", "source_character", "target_character", "encounter_side", "location", "explicit_entity"] },
          "effect_id": { "type": "string", "ui": { "widget": "reference", "reference": "effects", "label": "Effect" } },
          "status_id": { "type": "string", "ui": { "widget": "reference", "reference": "statuses", "label": "Status" } },
          "currency_id": { "type": "string", "ui": { "widget": "reference", "reference": "currencies", "label": "Currency" } },
          "quest_id": { "type": "string", "ui": { "widget": "reference", "reference": "quests", "label": "Quest" } },
          "item_id": { "type": "string", "ui": { "widget": "reference", "reference": "items", "label": "Item" } },
          "character_id": { "type": "string", "ui": { "widget": "reference", "reference": "characters", "label": "Character" } },
          "location_id": { "type": "string", "ui": { "widget": "reference", "reference": "locations", "label": "Location" } },
          "location_poi_id": { "type": "string", "ui": { "widget": "reference", "reference": "location_pois", "label": "POI" } },
          "variant_id": { "type": "string" },
          "amount": { "type": "number" },
          "required_count": { "type": "integer", "minimum": 1 },
          "stacks": { "type": "integer", "minimum": 1 },
          "duration": { "type": "number", "minimum": 0 },
          "removal_mode": { "type": "string", "enum": ["cleanse", "dispel", "system"] },
          "status_filter": { "type": "object", "properties": { "category": { "type": "string" }, "polarity": { "type": "string" }, "tag": { "type": "string" } } },
          "timing": { "type": "string", "enum": ["immediate", "after_completion", "on_turn_in"], "default": "after_completion" },
          "repeat_policy": { "type": "string", "enum": ["inherit_owner", "one_shot", "repeatable"], "default": "inherit_owner" },
          "sort_order": { "type": "integer", "minimum": 0 },
          "runtime_support": { "type": "string", "enum": ["runtime_unverified", "runtime_verified"], "default": "runtime_unverified" }
        },
        "required": ["id", "action_type", "target_scope", "timing", "repeat_policy", "sort_order", "runtime_support"]
      }
    },
    "outcome_transitions": {
      "type": "array",
      "description": "Typed authored transitions; defeat belongs to an encounter defeat policy.",
      "items": { "type": "object", "properties": { "id": { "type": "string" }, "trigger": { "type": "string", "enum": ["complete", "dialogue_choice", "victory", "interaction_closed", "condition", "fallback"] }, "target_event_id": { "type": "string", "ui": { "widget": "reference", "reference": "events" } }, "requirement_id": { "type": "string", "ui": { "widget": "reference", "reference": "requirements" } }, "source_ref_id": { "type": "string", "description": "Stable source choice/outcome identity when the trigger requires one." }, "label": { "type": "string" }, "sort_order": { "type": "integer", "minimum": 0 }, "runtime_support": { "type": "string", "enum": ["runtime_unverified", "runtime_verified"], "default": "runtime_unverified" } }, "required": ["id", "trigger", "sort_order", "runtime_support"] }
    },
    "repeat_policy": { "type": "string", "enum": ["inherit_owner", "one_shot", "repeatable"], "default": "inherit_owner", "ui": { "widget": "select", "label": "Repeat Policy" } },
    "runtime_support": { "type": "string", "enum": ["runtime_unverified", "runtime_verified"], "default": "runtime_unverified", "description": "Verification state for an external consumer, not web validation." },
    "flags_set": {
      "type": "array",
      "description": "Flags that will be set when the event completes",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Flags Set",
        "reference": "flags"
      }
    },
    "next_event_id": {
      "type": "string",
      "description": "Optional next event triggered automatically after this one",
      "ui": {
        "widget": "reference",
        "reference": "events",
        "label": "Next Event"
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorisation",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "title",
    "type"
  ]
}
