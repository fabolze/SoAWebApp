{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "ui": {
        "widget": "hidden"
      },
      "description": "Stable unique identifier for this item."
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Readable identifier used by rewards, shops, loot tables, and references."
    },
    "name": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "Item Name"
      },
      "description": "Player-facing item name."
    },
    "type": {
      "type": "string",
      "enum": [
        "Weapon",
        "Armor",
        "Accessory",
        "Consumable",
        "Tool",
        "Material",
        "Upgrade",
        "Quest",
        "SetPiece",
        "Misc"
      ],
      "ui": {
        "widget": "select",
        "label": "Item Type",
        "options": [
          "Weapon",
          "Armor",
          "Accessory",
          "Consumable",
          "Tool",
          "Material",
          "Upgrade",
          "Quest",
          "SetPiece",
          "Misc"
        ]
      },
      "description": "Broad item category used for filtering, equipment rules, and rewards."
    },
    "rarity": {
      "type": "string",
      "enum": [
        "Common",
        "Uncommon",
        "Rare",
        "Epic",
        "Legendary"
      ],
      "ui": {
        "widget": "select",
        "label": "Rarity"
      },
      "description": "Rarity tier used for balance, loot, shops, and presentation."
    },
    "description": {
      "type": "string",
      "ui": {
        "widget": "textarea",
        "label": "Description"
      },
      "description": "Player-facing or designer-facing explanation of what the item is."
    },
    "base_price": {
      "type": "number",
      "description": "Canonical value used as the baseline for shop pricing",
      "ui": {
        "widget": "number",
        "label": "Base Price"
      }
    },
    "base_currency_id": {
      "type": "string",
      "description": "Optional: currency for the base price (defaults to global currency if omitted)",
      "ui": {
        "widget": "reference",
        "reference": "currencies",
        "label": "Base Currency"
      }
    },
    "equipment_slot": {
      "type": "string",
      "enum": [
        "head",
        "chest",
        "legs",
        "feet",
        "hands",
        "belt",
        "ring",
        "amulet",
        "back",
        "main_hand",
        "off_hand",
        "two_hand",
        "accessory",
        "mount",
        "pet"
      ],
      "ui": {
        "widget": "select",
        "label": "Equipment Slot",
        "visible_if": {
          "type": [
            "Weapon",
            "Armor",
            "Accessory",
            "SetPiece",
            "Tool"
          ]
        }
      },
      "description": "Equipment slot this item occupies when equipped."
    },
    "weapon_type": {
      "type": "string",
      "enum": [
        "Greatsword",
        "Longsword",
        "Shortsword",
        "Dagger",
        "Rapier",
        "Axe",
        "Greataxe",
        "Hammer",
        "Mace",
        "Spear",
        "Polearm",
        "Halberd",
        "Staff",
        "Wand",
        "Tome",
        "Bow",
        "Crossbow",
        "Firearm",
        "Thrown",
        "Unarmed",
        "Shield",
        "Focus",
        "Instrument"
      ],
      "ui": {
        "widget": "select",
        "label": "Weapon Type",
        "visible_if": {
          "type": [
            "Weapon"
          ]
        }
      },
      "description": "Weapon family or handling type for combat rules."
    },
    "damage_type": {
      "type": "string",
      "enum": [
        "Slashing",
        "Piercing",
        "Blunt",
        "Fire",
        "Water",
        "Air",
        "Earth",
        "Poison",
        "Psychic",
        "Light",
        "Shadow"
      ],
      "ui": {
        "widget": "select",
        "label": "Damage Type",
        "visible_if": {
          "type": [
            "Weapon"
          ]
        }
      },
      "description": "Damage type dealt or modified by this item."
    },
    "weapon_range_type": {
      "type": "string",
      "enum": [
        "melee",
        "range"
      ],
      "ui": {
        "widget": "select",
        "label": "Weapon Range Type",
        "visible_if": {
          "type": [
            "Weapon"
          ]
        }
      },
      "description": "How this weapon reaches targets, such as melee, ranged, or area."
    },
    "weapon_range": {
      "type": "integer",
      "ui": {
        "widget": "number",
        "label": "Weapon Range",
        "visible_if": {
          "type": [
            "Weapon"
          ]
        }
      },
      "description": "Effective range or reach value used by combat rules."
    },
    "stat_modifiers": {
      "type": "array",
      "description": "List of stat bonuses or penalties applied while the item is equipped",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "ui": {
              "widget": "hidden"
            },
            "description": "Stable identifier for this stat modifier row."
          },
          "stat_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "stats",
              "label": "Stat"
            },
            "description": "Stat changed by this item modifier."
          },
          "value": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Value"
            },
            "description": "Amount added, removed, or otherwise applied to the selected stat."
          },
          "value_type": {
            "type": "string",
            "enum": [
              "Flat",
              "Percentage",
              "Multiplier"
            ],
            "ui": {
              "widget": "select",
              "label": "Value Type",
              "description": "Flat applies raw value, Percentage multiplies current stat, Multiplier stacks multiplicatively"
            }
          },
          "scaling_behavior": {
            "type": "string",
            "enum": [
              "None",
              "Linear",
              "Exponential",
              "Logarithmic",
              "Custom"
            ],
            "ui": {
              "widget": "select",
              "label": "Scaling Behavior",
              "options": [
                "None",
                "Linear",
                "Exponential",
                "Logarithmic",
                "Custom"
              ]
            },
            "description": "How this stat modifier scales or stacks over time."
          },
          "notes": {
            "type": "string",
            "ui": {
              "widget": "textarea",
              "label": "Designer Notes"
            },
            "description": "Designer notes explaining intent, balance, or special cases for this modifier."
          }
        },
        "required": [
          "stat_id",
          "value"
        ]
      },
      "ui": {
        "label": "Stat Modifiers",
        "description": "Define each stat this item modifies. Use value type and scaling to control how the bonus interacts with character growth."
      }
    },
    "attribute_modifiers": {
      "type": "array",
      "description": "Attribute bonuses granted while equipped",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "ui": {
              "widget": "hidden"
            },
            "description": "Stable identifier for this attribute modifier row."
          },
          "attribute_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "attributes",
              "label": "Attribute"
            },
            "description": "Attribute changed by this item modifier."
          },
          "value": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Value"
            },
            "description": "Amount added, removed, or otherwise applied to the selected attribute."
          },
          "scaling": {
            "type": "string",
            "enum": [
              "None",
              "Linear",
              "Exponential",
              "Logarithmic",
              "Custom"
            ],
            "ui": {
              "widget": "select",
              "label": "Scaling"
            },
            "description": "How this attribute modifier scales or stacks over time."
          },
          "notes": {
            "type": "string",
            "ui": {
              "widget": "textarea",
              "label": "Designer Notes"
            },
            "description": "Designer notes explaining intent, balance, or special cases for this modifier."
          }
        },
        "required": [
          "attribute_id",
          "value"
        ]
      },
      "ui": {
        "label": "Attribute Modifiers",
        "description": "Optional attribute bonuses that feed into downstream stat calculations."
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Effects",
        "options_source": "schemas/effects.json"
      },
      "description": "Effects triggered, granted, or applied by this item."
    },
    "is_unique": { "type": "boolean", "default": false, "description": "Only one canonical/player-owned instance is intended." },
    "is_protected": { "type": "boolean", "default": false, "description": "Protected items cannot be casually sold, dropped, or destroyed." },
    "consumption_policy": { "type": "string", "enum": ["ordinary", "never_consume", "consume_on_use", "consume_on_turn_in"], "default": "ordinary" },
    "variants": { "type": "array", "description": "Stable stages of one evolving item identity.", "items": { "type": "object", "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "stage": { "type": "integer" }, "overrides": { "type": "object" } }, "required": ["id", "label", "overrides"] } },
    "requirements_id": {
      "type": "string",
      "description": "Requirement to use this item",
      "ui": {
        "widget": "reference",
        "reference": "requirements",
        "label": "Requirements"
      }
    },
    "icon_path": {
      "type": "string",
      "description": "Optional icon for this item",
      "ui": {
        "widget": "filepicker",
        "label": "Icon"
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "name",
    "type",
    "base_price"
  ]
}
