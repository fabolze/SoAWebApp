{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ability",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier",
      "ui": {
        "widget": "hidden"
      }
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Stable identifier used to reference this ability from items, characters, encounters, and effects."
    },
    "name": {
      "type": "string",
      "description": "Display name of the ability",
      "ui": {
        "widget": "text",
        "label": "Ability Name"
      }
    },
    "type": {
      "type": "string",
      "enum": [
        "Active",
        "Passive",
        "Toggle"
      ],
      "description": "Ability type",
      "ui": {
        "widget": "select",
        "label": "Ability Type",
        "options": [
          "Active",
          "Passive",
          "Toggle"
        ]
      }
    },
    "icon_path": {
      "type": "string",
      "description": "Icon representing this ability",
      "ui": {
        "widget": "filepicker",
        "label": "Icon Path"
      }
    },
    "description": {
      "type": "string",
      "description": "What this ability does, shown in the UI",
      "ui": {
        "widget": "textarea",
        "label": "Description"
      }
    },
    "resource_cost": {
      "type": "number",
      "description": "Mana or stamina required to use",
      "ui": {
        "widget": "number",
        "label": "Cost"
      }
    },
    "cooldown": {
      "type": "number",
      "description": "Cooldown time in turns or seconds",
      "ui": {
        "widget": "number",
        "label": "Cooldown"
      }
    },
    "cast_time": {
      "type": "number",
      "description": "Abstract turns between activation and impact.",
      "ui": { "widget": "number", "label": "Cast Time" }
    },
    "recovery_time": {
      "type": "number",
      "description": "Abstract turns before the user may act again.",
      "ui": { "widget": "number", "label": "Recovery Time" }
    },
    "upkeep_cost": {
      "type": "number",
      "description": "Resource paid each active turn by Toggle abilities.",
      "ui": { "widget": "number", "label": "Toggle Upkeep" }
    },
    "max_targets": {
      "type": "integer",
      "description": "Optional cap on targets affected by this ability.",
      "ui": { "widget": "number", "label": "Max Targets" }
    },
    "targeting": {
      "type": "string",
      "enum": [
        "Single",
        "Area",
        "Self",
        "Allies",
        "Enemies"
      ],
      "description": "Target type for the ability",
      "ui": {
        "widget": "select",
        "label": "Targeting",
        "options": [
          "Single",
          "Area",
          "Self",
          "Allies",
          "Enemies"
        ]
      }
    },
    "trigger_condition": {
      "type": "string",
      "enum": [
        "On Use",
        "Passive",
        "On Hit",
        "When Damaged",
        "On Kill"
      ],
      "description": "When the ability activates",
      "ui": {
        "widget": "select",
        "label": "Trigger Condition",
        "options": [
          "On Use",
          "Passive",
          "On Hit",
          "When Damaged",
          "On Kill"
        ]
      }
    },
    "damage_type_source": {
      "type": "string",
      "enum": [
        "Weapon",
        "Fixed",
        "None"
      ],
      "default": "None",
      "description": "Where this ability takes its damage type from",
      "ui": {
        "widget": "select",
        "label": "Damage Type Source",
        "options": [
          "Weapon",
          "Fixed",
          "None"
        ]
      }
    },
    "damage_type": {
      "type": "string",
      "enum": [
        "Slashing",
        "Piercing",
        "Blunt",
        "Fire",
        "Water",
        "Air",
        "Earth",
        "Poison",
        "Psychic",
        "Light",
        "Shadow"
      ],
      "description": "Fixed damage type when source is Fixed",
      "ui": {
        "widget": "select",
        "label": "Damage Type",
        "visible_if": {
          "damage_type_source": [
            "Fixed"
          ]
        }
      }
    },
    "effects": {
      "type": "array",
      "description": "List of effects applied by this ability",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Effects",
        "reference": "effects"
      }
    },
    "scaling": {
      "type": "array",
      "description": "Scaling formulas for this ability (e.g. damage based on Physical Attack)",
      "items": {
        "type": "object",
        "properties": {
          "stat_id": {
            "type": "string",
            "description": "ID of the scaling stat",
            "ui": {
              "widget": "select",
              "label": "Stat",
              "reference": "stats"
            }
          },
          "multiplier": {
            "type": "number",
            "description": "How much the stat contributes",
            "ui": {
              "widget": "number",
              "label": "Multiplier"
            }
          }
        },
        "required": [
          "stat_id",
          "multiplier"
        ]
      }
    },
    "requirements_id": {
      "type": "string",
      "description": "Requirement to unlock/use this ability",
      "ui": {
        "widget": "reference",
        "reference": "requirements",
        "label": "Requirements"
      }
    },
    "effect_links": {
      "type": "array",
      "description": "Timed payload links. When omitted, effects execute at Impact with offset 0.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "effect_id": { "type": "string" },
          "phase": { "type": "string", "enum": ["Cast", "Impact", "Aftermath", "WhileActive", "Deactivate"] },
          "turn_offset": { "type": "number" },
          "sort_order": { "type": "integer" }
        },
        "required": ["effect_id"]
      }
    },
    "design_intent": {
      "type": "string",
      "description": "The player-facing decision or promise this ability creates.",
      "ui": { "widget": "textarea", "label": "Design Intent" }
    },
    "counterplay_notes": {
      "type": "string",
      "description": "How affected players can understand and answer the ability.",
      "ui": { "widget": "textarea", "label": "Counterplay" }
    },
    "mastery_notes": {
      "type": "string",
      "description": "Advanced uses and mastery opportunities.",
      "ui": { "widget": "textarea", "label": "Mastery" }
    },
    "presentation_notes": {
      "type": "string",
      "description": "Visual, sound, and readability direction.",
      "ui": { "widget": "textarea", "label": "Presentation" }
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "name",
    "type"
  ]
}
