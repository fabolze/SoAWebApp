{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Status",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "ui": {
        "widget": "hidden"
      },
      "description": "Stable unique identifier for this status."
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Readable identifier used by effects, abilities, items, and combat rules."
    },
    "name": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "Status Name"
      },
      "description": "Player-facing or designer-facing status name."
    },
    "category": {
      "type": "string",
      "enum": [
        "Buff",
        "Debuff",
        "Control",
        "DoT",
        "Other"
      ],
      "ui": {
        "widget": "select",
        "label": "Category",
        "options": [
          "Buff",
          "Debuff",
          "Control",
          "DoT",
          "Other"
        ]
      },
      "description": "Status grouping used for stacking, filtering, and UI presentation."
    },
    "polarity": {
      "type": "string",
      "enum": ["Beneficial", "Harmful", "Neutral"],
      "description": "Whether the status helps, harms, or is context-neutral.",
      "ui": { "widget": "select", "label": "Polarity" }
    },
    "description": {
      "type": "string",
      "ui": {
        "widget": "textarea",
        "label": "Description"
      },
      "description": "Short explanation of what the status does or represents."
    },
    "default_duration": {
      "type": "number",
      "description": "Default duration in seconds when no effect override is provided",
      "ui": {
        "widget": "number",
        "label": "Default Duration"
      }
    },
    "stackable": {
      "type": "boolean",
      "description": "Whether this status can stack",
      "ui": {
        "widget": "checkbox",
        "label": "Stackable"
      }
    },
    "max_stacks": {
      "type": "integer",
      "description": "Maximum stacks allowed if stackable",
      "ui": {
        "widget": "number",
        "label": "Max Stacks"
      }
    },
    "reapplication_policy": {
      "type": "string",
      "enum": ["RefreshDuration", "Replace", "Ignore", "AddStackRefresh", "AddIndependentStack"],
      "description": "How reapplying an active status changes it.",
      "ui": { "widget": "select", "label": "Reapplication" }
    },
    "stack_decay_policy": {
      "type": "string",
      "enum": ["AllAtOnce", "OnePerDuration", "Independent"],
      "description": "How stacked instances expire.",
      "ui": { "widget": "select", "label": "Stack Decay" }
    },
    "can_cleanse": {
      "type": "boolean",
      "description": "Whether allied removal operations may remove this status.",
      "ui": { "widget": "checkbox", "label": "Can Cleanse" }
    },
    "can_dispel": {
      "type": "boolean",
      "description": "Whether hostile removal operations may remove this status.",
      "ui": { "widget": "checkbox", "label": "Can Dispel" }
    },
    "icon_path": {
      "type": "string",
      "ui": {
        "widget": "filepicker",
        "label": "Icon"
      },
      "description": "Optional icon asset used to represent this status in UI."
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "name"
  ]
}
