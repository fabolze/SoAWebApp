{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Location",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID for the location",
      "ui": {
        "widget": "hidden"
      }
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Stable identifier used to reference this location from characters, quests, events, and encounters."
    },
    "name": {
      "type": "string",
      "description": "Display name of the location",
      "ui": {
        "widget": "text",
        "label": "Location Name"
      }
    },
    "description": {
      "type": "string",
      "description": "Description shown to player",
      "ui": {
        "widget": "textarea",
        "label": "Description"
      }
    },
    "biome": {
      "type": "string",
      "enum": [
        "Plains",
        "Forest",
        "Cave",
        "Mountain",
        "Desert",
        "Swamp",
        "Coast",
        "Tundra",
        "City",
        "Ruins",
        "Fortress",
        "Sky Isles",
        "Cloud Sea",
        "Crystal Caverns",
        "Magma Veins",
        "Fungal Undergrowth",
        "Abyss"
      ],
      "ui": {
        "widget": "select",
        "label": "Biome",
        "options": [
          "Plains",
          "Forest",
          "Cave",
          "Mountain",
          "Desert",
          "Swamp",
          "Coast",
          "Tundra",
          "City",
          "Ruins",
          "Fortress",
          "Sky Isles",
          "Cloud Sea",
          "Crystal Caverns",
          "Magma Veins",
          "Fungal Undergrowth",
          "Abyss"
        ]
      },
      "description": "Optional ecology, spawning, travel, or ambience layer for this location. Use place_kind for what the location actually is."
    },
    "biome_modifier": {
      "type": "string",
      "description": "Optional magical layer that alters the base biome",
      "enum": [
        "Arcane",
        "Corrupted",
        "Divine",
        "Shadowed",
        "Dreamlike"
      ],
      "ui": {
        "widget": "select",
        "label": "Biome Modifier",
        "options": [
          "Arcane",
          "Corrupted",
          "Divine",
          "Shadowed",
          "Dreamlike"
        ]
      }
    },
    "region": {
      "type": "string",
      "description": "Map region or continent",
      "ui": {
        "widget": "text",
        "label": "Region"
      }
    },
    "place_kind": {
      "type": "string",
      "description": "What kind of place this location is, independent from ecology or biome.",
      "enum": [
        "Wilderness",
        "Settlement",
        "Dungeon",
        "Interior",
        "Road",
        "Waterway",
        "Landmark",
        "AbstractRegion",
        "Other"
      ],
      "ui": {
        "widget": "select",
        "label": "Place Kind",
        "options": [
          "Wilderness",
          "Settlement",
          "Dungeon",
          "Interior",
          "Road",
          "Waterway",
          "Landmark",
          "AbstractRegion",
          "Other"
        ]
      }
    },
    "environment_tags": {
      "type": "array",
      "description": "World-design descriptors such as village, river, sewer, market, underground, sacred, or flooded.",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Environment Tags"
      }
    },
    "biome_inheritance": {
      "type": "string",
      "description": "How this location resolves its ecology biome. Leave unset for automatic behavior based on location type.",
      "enum": [
        "Own",
        "InheritFromParent",
        "None",
        "Mixed"
      ],
      "ui": {
        "widget": "select",
        "label": "Biome Inheritance",
        "options": [
          "Own",
          "InheritFromParent",
          "None",
          "Mixed"
        ]
      }
    },
    "parent_location_id": {
      "type": "string",
      "description": "Optional parent location used for world hierarchy.",
      "ui": {
        "widget": "reference",
        "reference": "locations",
        "label": "Parent Location"
      }
    },
    "location_type": {
      "type": "string",
      "description": "World-building hierarchy type for this location.",
      "enum": [
        "World",
        "Continent",
        "Region",
        "Zone",
        "Subzone",
        "Room",
        "Interior"
      ],
      "ui": {
        "widget": "select",
        "label": "Location Type",
        "options": [
          "World",
          "Continent",
          "Region",
          "Zone",
          "Subzone",
          "Room",
          "Interior"
        ]
      }
    },
    "sort_order": {
      "type": "integer",
      "description": "Ordering value inside the parent hierarchy.",
      "ui": {
        "widget": "number",
        "label": "Sort Order"
      }
    },
    "is_playable_space": {
      "type": "boolean",
      "description": "Whether this location represents a playable space.",
      "ui": {
        "widget": "checkbox",
        "label": "Playable Space"
      }
    },
    "is_world_map_node": {
      "type": "boolean",
      "description": "Whether this location should appear as a world-map node.",
      "ui": {
        "widget": "checkbox",
        "label": "World Map Node"
      }
    },
    "level_range": {
      "type": "object",
      "description": "Recommended level range for encounters",
      "properties": {
        "min": {
          "type": "number",
          "description": "Lowest suggested player or content level for this location."
        },
        "max": {
          "type": "number",
          "description": "Highest suggested player or content level for this location."
        }
      }
    },
    "coordinates": {
      "type": "object",
      "description": "Position on world map",
      "properties": {
        "x": {
          "type": "number",
          "description": "Horizontal map coordinate for placing this location."
        },
        "y": {
          "type": "number",
          "description": "Vertical map coordinate for placing this location."
        }
      }
    },
    "image_path": {
      "type": "string",
      "description": "Optional image or map segment",
      "ui": {
        "widget": "filepicker",
        "label": "Image"
      }
    },
    "encounters": {
      "type": "array",
      "description": "Encounters that can be triggered in this location",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Encounters",
        "reference": "encounters"
      }
    },
    "is_safe_zone": {
      "type": "boolean",
      "description": "True if this is a no-combat zone",
      "ui": {
        "widget": "checkbox",
        "label": "Safe Zone"
      }
    },
    "is_fast_travel_point": {
      "type": "boolean",
      "description": "Whether this location can be used for fast travel",
      "ui": {
        "widget": "checkbox",
        "label": "Fast Travel"
      }
    },
    "has_respawn_point": {
      "type": "boolean",
      "description": "If defeated, players respawn here",
      "ui": {
        "widget": "checkbox",
        "label": "Respawn Point"
      }
    },
    "tags": {
      "type": "array",
      "description": "Keywords for filtering or categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    },
    "variants": { "type": "array", "description": "Stateful intact/damaged/presentation variants with a bounded override set.", "items": { "type": "object", "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "state": { "type": "string" }, "overrides": { "type": "object" } }, "required": ["id", "label", "overrides"] } }
  },
  "required": [
    "id",
    "slug",
    "name"
  ]
}
