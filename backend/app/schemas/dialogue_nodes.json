{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dialogue Node",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID for this dialogue node",
      "ui": {
        "widget": "hidden"
      }
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Stable identifier used when linking dialogue flow to this node."
    },
    "dialogue_id": {
      "type": "string",
      "description": "Parent dialogue this node belongs to",
      "ui": {
        "widget": "reference",
        "reference": "dialogues",
        "label": "Dialogue"
      }
    },
    "speaker": {
      "type": "string",
      "description": "Who is speaking at this node",
      "ui": {
        "widget": "text",
        "label": "Speaker"
      }
    },
    "speaker_character_id": {
      "type": "string",
      "description": "Optional canonical character identity for this speaker.",
      "ui": {
        "widget": "reference",
        "reference": "characters",
        "label": "Speaker Character"
      }
    },
    "text": {
      "type": "string",
      "description": "The dialogue text",
      "ui": {
        "widget": "textarea",
        "label": "Dialogue Text"
      }
    },
    "is_terminal": {
      "type": "boolean",
      "description": "Marks this node as an intentional ending. Terminal nodes cannot have outgoing choices.",
      "default": false,
      "ui": {
        "widget": "checkbox",
        "label": "Terminal Node"
      }
    },
    "choices": {
      "type": "array",
      "description": "List of choices or automatic next nodes",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Immutable choice identity used by typed actions, transitions, and replay protection",
            "ui": {
              "widget": "hidden"
            }
          },
          "choice_id": {
            "type": "string",
            "description": "Backward-compatible alias for immutable choice identity."
          },
          "choice_text": {
            "type": "string",
            "description": "Text shown for this choice (optional for auto-continue)"
          },
          "next_node_id": {
            "type": "string",
            "description": "Optional next dialogue node. May be omitted when a typed action owns continuation or termination.",
            "ui": {
              "widget": "reference",
              "reference": "dialogue-nodes",
              "label": "Next Node"
            }
          },
          "requirements_id": {
            "type": "string",
            "description": "Requirement to unlock this choice",
            "ui": {
              "widget": "reference",
              "reference": "requirements",
              "label": "Requirements"
            }
          },
          "set_flags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "ui": {
              "widget": "multiselect",
              "reference": "flags",
              "label": "Flags Set (Choice)"
            },
            "description": "Flags set when the player chooses this response."
          },
          "actions": {
            "type": "array",
            "description": "Typed ordered gameplay handoffs owned by this stable choice.",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Immutable action and replay-protection identity"
                },
                "action_id": {
                  "type": "string",
                  "description": "Backward-compatible alias for action identity"
                },
                "action_type": {
                  "type": "string",
                  "enum": ["open_shop", "start_encounter", "join_companion"]
                },
                "target_shop_id": {
                  "type": "string",
                  "ui": {"widget": "reference", "reference": "shops", "label": "Shop"}
                },
                "target_encounter_id": {
                  "type": "string",
                  "ui": {"widget": "reference", "reference": "encounters", "label": "Encounter"}
                },
                "target_character_id": {
                  "type": "string",
                  "ui": {"widget": "reference", "reference": "characters", "label": "Companion"}
                },
                "target_ref_type": {
                  "type": "string",
                  "enum": ["shop", "encounter", "character", "quest", "location_poi"]
                },
                "target_ref_id": {"type": "string"},
                "timing": {"type": "string", "enum": ["immediate", "after_completion", "on_turn_in"]},
                "repeat_policy": {"type": "string", "enum": ["inherit_owner", "one_shot", "repeatable"]},
                "continuation_policy": {
                  "type": "string",
                  "enum": ["resume_source_dialogue", "continue_dialogue", "end_source_dialogue"]
                },
                "sort_order": {
                  "type": "integer",
                  "minimum": 0
                },
                "runtime_support": {
                  "type": "string",
                  "enum": ["runtime_unverified", "runtime_verified"],
                  "default": "runtime_unverified"
                }
              },
              "required": ["id", "action_type", "continuation_policy", "sort_order", "runtime_support"]
            }
          }
        },
        "required": [
          "id"
        ]
      }
    },
    "requirements_id": {
      "type": "string",
      "description": "Requirement to unlock this node",
      "ui": {
        "widget": "reference",
        "reference": "requirements",
        "label": "Requirements"
      }
    },
    "set_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "reference": "flags",
        "label": "Flags Set (Node)"
      },
      "description": "Flags set when this dialogue node is reached or resolved."
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "dialogue_id",
    "speaker",
    "text"
  ]
}
