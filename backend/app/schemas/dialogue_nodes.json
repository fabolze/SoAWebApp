{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dialogue Node",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID for this dialogue node",
      "ui": {
        "widget": "hidden"
      }
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Stable identifier used when linking dialogue flow to this node."
    },
    "dialogue_id": {
      "type": "string",
      "description": "Parent dialogue this node belongs to",
      "ui": {
        "widget": "reference",
        "reference": "dialogues",
        "label": "Dialogue"
      }
    },
    "speaker": {
      "type": "string",
      "description": "Who is speaking at this node",
      "ui": {
        "widget": "text",
        "label": "Speaker"
      }
    },
    "speaker_character_id": {
      "type": "string",
      "description": "Optional canonical character identity for this speaker.",
      "ui": {
        "widget": "reference",
        "reference": "characters",
        "label": "Speaker Character"
      }
    },
    "text": {
      "type": "string",
      "description": "The dialogue text",
      "ui": {
        "widget": "textarea",
        "label": "Dialogue Text"
      }
    },
    "is_terminal": {
      "type": "boolean",
      "description": "Marks this node as an intentional ending. Terminal nodes cannot have outgoing choices.",
      "default": false,
      "ui": {
        "widget": "checkbox",
        "label": "Terminal Node"
      }
    },
    "choices": {
      "type": "array",
      "description": "List of choices or automatic next nodes",
      "items": {
        "type": "object",
        "properties": {
          "choice_id": {
            "type": "string",
            "description": "Immutable choice identity used by actions, transitions, and replay protection. Legacy choices receive a deterministic id when loaded or saved."
          },
          "choice_text": {
            "type": "string",
            "description": "Text shown for this choice (optional for auto-continue)"
          },
          "next_node_id": {
            "type": "string",
            "description": "ID of the next dialogue node",
            "ui": {
              "widget": "reference",
              "reference": "dialogue-nodes",
              "label": "Next Node"
            }
          },
          "requirements_id": {
            "type": "string",
            "description": "Requirement to unlock this choice",
            "ui": {
              "widget": "reference",
              "reference": "requirements",
              "label": "Requirements"
            }
          },
          "set_flags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "ui": {
              "widget": "multiselect",
              "reference": "flags",
              "label": "Flags Set (Choice)"
            },
            "description": "Flags set when the player chooses this response."
          },
          "actions": {
            "type": "array",
            "description": "Ordered typed actions owned by this stable choice. Web export is runtime_unverified until an external consumer is verified.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "action_id": { "type": "string", "description": "Stable replay-protection identity." },
                "action_type": {
                  "type": "string",
                  "enum": ["open_shop", "start_encounter", "join_companion", "discover_quest", "assign_quest", "reveal_map_marker"]
                },
                "target_ref_type": {
                  "type": "string",
                  "enum": ["shop", "encounter", "character", "quest", "location_poi"]
                },
                "target_ref_id": { "type": "string" },
                "timing": { "type": "string", "enum": ["immediate", "after_completion", "on_turn_in"] },
                "repeat_policy": { "type": "string", "enum": ["inherit_owner", "one_shot", "repeatable"] },
                "continuation_policy": {
                  "type": "string",
                  "enum": ["advance_to_next_node", "resume_source_dialogue", "end_source_dialogue", "return_to_origin"]
                },
                "sort_order": { "type": "integer", "minimum": 0 },
                "runtime_support": { "type": "string", "enum": ["runtime_unverified", "runtime_verified"] }
              },
              "required": [
                "action_id", "action_type", "target_ref_type", "target_ref_id", "timing",
                "repeat_policy", "continuation_policy", "sort_order", "runtime_support"
              ]
            }
          }
        },
        "required": [
          "choice_id",
          "next_node_id"
        ]
      }
    },
    "requirements_id": {
      "type": "string",
      "description": "Requirement to unlock this node",
      "ui": {
        "widget": "reference",
        "reference": "requirements",
        "label": "Requirements"
      }
    },
    "set_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "reference": "flags",
        "label": "Flags Set (Node)"
      },
      "description": "Flags set when this dialogue node is reached or resolved."
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "dialogue_id",
    "speaker",
    "text"
  ]
}
