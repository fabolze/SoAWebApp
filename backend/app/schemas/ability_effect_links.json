{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ability Effect Link",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "ability_id": { "type": "string" },
    "effect_id": { "type": "string" },
    "phase": { "type": "string", "enum": ["Cast", "Impact", "Aftermath", "WhileActive", "Deactivate"] },
    "turn_offset": { "type": "number" },
    "sort_order": { "type": "integer" }
  },
  "required": ["id", "ability_id", "effect_id"]
}
