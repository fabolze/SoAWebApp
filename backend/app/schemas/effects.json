{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Effect",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "ui": {
        "widget": "hidden"
      },
      "description": "Stable unique identifier for this effect."
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Readable identifier used by abilities, items, statuses, and other effect references."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the effect, e.g., 'Stun', 'Heal %'",
      "ui": {
        "widget": "text",
        "label": "Effect Name"
      }
    },
    "type": {
      "type": "string",
      "enum": [
        "Status",
        "Damage",
        "Heal",
        "Modifier",
        "Reflect",
        "Summon",
        "Shield",
        "Control"
      ],
      "description": "Category of effect",
      "ui": {
        "widget": "select",
        "label": "Effect Type",
        "options": [
          "Status",
          "Damage",
          "Heal",
          "Modifier",
          "Reflect",
          "Summon",
          "Shield",
          "Control"
        ]
      }
    },
    "description": {
      "type": "string",
      "description": "In-game UI description of what the effect does",
      "ui": {
        "widget": "textarea",
        "label": "Description"
      }
    },
    "target": {
      "type": "string",
      "enum": [
        "Self",
        "Enemy",
        "Ally",
        "All",
        "Area"
      ],
      "description": "Who the effect applies to",
      "ui": {
        "widget": "select",
        "label": "Target",
        "options": [
          "Self",
          "Enemy",
          "Ally",
          "All",
          "Area"
        ]
      }
    },
    "duration": {
      "type": "number",
      "description": "Duration in seconds; 0 = instant, -1 = permanent",
      "ui": {
        "widget": "number",
        "label": "Duration"
      }
    },
    "value_type": {
      "type": "string",
      "enum": [
        "Flat",
        "Percentage",
        "None"
      ],
      "description": "How to interpret the value (flat number or percent)",
      "ui": {
        "widget": "select",
        "label": "Value Type",
        "options": [
          "Flat",
          "Percentage",
          "None"
        ]
      }
    },
    "value": {
      "type": "number",
      "description": "Numerical effect amount (e.g. 50 HP or 20% if value_type is 'Percentage')",
      "ui": {
        "widget": "number",
        "label": "Effect Value"
      }
    },
    "calculation_basis": {
      "type": "string",
      "enum": [
        "Fixed Value",
        "Source Stat",
        "Weapon Damage",
        "Damage Dealt",
        "Source Max Health",
        "Target Max Health"
      ],
      "description": "Runtime basis used by the effect resolver before value_type, value, and scaling are applied.",
      "ui": {
        "widget": "select",
        "label": "Calculation Basis",
        "options": [
          "Fixed Value",
          "Source Stat",
          "Weapon Damage",
          "Damage Dealt",
          "Source Max Health",
          "Target Max Health"
        ]
      }
    },
    "scaling_multiplier": {
      "type": "number",
      "description": "Multiplier applied to scaling_stat_id when calculation_basis uses source stat scaling.",
      "ui": {
        "widget": "number",
        "label": "Scaling Multiplier"
      }
    },
    "damage_type": {
      "type": "string",
      "enum": [
        "Slashing",
        "Piercing",
        "Blunt",
        "Fire",
        "Water",
        "Air",
        "Earth",
        "Poison",
        "Psychic",
        "Light",
        "Shadow"
      ],
      "description": "Damage element or school used by Damage effects and damaging status ticks.",
      "ui": {
        "widget": "select",
        "label": "Damage Type",
        "options": [
          "Slashing",
          "Piercing",
          "Blunt",
          "Fire",
          "Water",
          "Air",
          "Earth",
          "Poison",
          "Psychic",
          "Light",
          "Shadow"
        ],
        "visible_if": {
          "type": [
            "Damage",
            "Status",
            "Reflect"
          ]
        }
      }
    },
    "tick_interval": {
      "type": "number",
      "description": "Seconds between repeated ticks for status, heal-over-time, or damage-over-time effects.",
      "ui": {
        "widget": "number",
        "label": "Tick Interval"
      }
    },
    "status_id": {
      "type": "string",
      "description": "Status to apply when this effect triggers",
      "ui": {
        "widget": "select",
        "label": "Status",
        "reference": "statuses",
        "visible_if": {
          "type": [
            "Status"
          ]
        }
      }
    },
    "apply_chance": {
      "type": "number",
      "description": "Chance in percent to apply the status (0-100)",
      "ui": {
        "widget": "number",
        "label": "Apply Chance (%)",
        "visible_if": {
          "type": [
            "Status"
          ]
        }
      }
    },
    "status_operation": {
      "type": "string",
      "enum": ["Apply", "Remove", "GrantImmunity"],
      "description": "Operation performed by a Status effect.",
      "ui": { "widget": "select", "label": "Status Operation" }
    },
    "status_filter": {
      "type": "object",
      "description": "Filter used by remove and immunity operations.",
      "ui": { "widget": "object", "label": "Status Filter" }
    },
    "attribute_id": {
      "type": "string",
      "description": "Attribute affected, if any",
      "ui": {
        "widget": "select",
        "label": "Affected Attribute",
        "reference": "attributes",
        "visible_if": {
          "type": [
            "Modifier",
            "Shield"
          ]
        }
      }
    },
    "scaling_stat_id": {
      "type": "string",
      "description": "Stat that determines effect scaling",
      "ui": {
        "widget": "select",
        "label": "Scaling Stat",
        "reference": "stats"
      }
    },
    "trigger_condition": {
      "type": "string",
      "enum": [
        "None",
        "On Hit",
        "When Damaged",
        "On Kill",
        "On Cast",
        "Passive"
      ],
      "description": "Trigger condition for this effect",
      "ui": {
        "widget": "select",
        "label": "Trigger Condition",
        "options": [
          "None",
          "On Hit",
          "When Damaged",
          "On Kill",
          "On Cast",
          "Passive"
        ]
      }
    },
    "stackable": {
      "type": "boolean",
      "description": "Whether this effect can stack multiple times",
      "ui": {
        "widget": "checkbox",
        "label": "Stackable"
      }
    },
    "set_bonus_group": {
      "type": "string",
      "description": "Set group identifier for tracking combined effects",
      "ui": {
        "widget": "text",
        "label": "Set Bonus Group"
      }
    },
    "icon_path": {
      "type": "string",
      "description": "Path to icon representing this effect",
      "ui": {
        "widget": "filepicker",
        "label": "Icon Path"
      }
    },
    "related_items": {
      "type": "array",
      "description": "List of item IDs that apply this effect",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Related Items",
        "reference": "items"
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "name",
    "type",
    "target"
  ]
}
