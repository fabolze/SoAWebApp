{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quest",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID for the quest",
      "ui": {
        "widget": "hidden"
      }
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Stable identifier used to reference this quest from dialogue, events, requirements, and rewards."
    },
    "title": {
      "type": "string",
      "description": "Quest title",
      "ui": {
        "widget": "text",
        "label": "Title"
      }
    },
    "description": {
      "type": "string",
      "description": "Quest description shown to player",
      "ui": {
        "widget": "textarea",
        "label": "Description"
      }
    },
    "story_arc_id": {
      "type": "string",
      "description": "Which story arc this quest belongs to",
      "ui": {
        "widget": "reference",
        "reference": "story-arcs",
        "label": "Story Arc"
      }
    },
    "requirements_id": {
      "type": "string",
      "description": "Requirement to unlock this quest",
      "ui": {
        "widget": "reference",
        "reference": "requirements",
        "label": "Requirements"
      }
    },
    "objectives": {
      "type": "array",
      "description": "List of objectives within the quest",
      "items": {
        "type": "object",
        "properties": {
          "objective_id": {
            "type": "string",
            "description": "Internal ID for this objective"
          },
          "description": {
            "type": "string",
            "description": "Player-facing description of this objective"
          },
          "requirements_id": {
            "type": "string",
            "description": "Requirement to unlock this objective",
            "ui": {
              "widget": "reference",
              "reference": "requirements",
              "label": "Requirements"
            }
          },
          "flags_set": {
            "type": "array",
            "description": "Flags to set when this objective is completed",
            "items": {
              "type": "string"
            },
            "ui": {
              "widget": "multiselect",
              "label": "Flags Set",
              "reference": "flags"
            }
          },
          "objective_type": { "type": "string", "enum": ["custom", "inventory_count", "interaction", "encounter", "location"], "default": "custom" },
          "item_id": { "type": "string", "ui": { "widget": "reference", "reference": "items", "label": "Tracked Item" } },
          "required_count": { "type": "integer", "minimum": 1, "default": 1 },
          "inventory_scope": { "type": "string", "enum": ["current_inventory"], "default": "current_inventory" },
          "consumption_policy": { "type": "string", "enum": ["keep", "consume_on_turn_in", "consume_on_progress"], "default": "keep" }
        },
        "required": [
          "objective_id",
          "description"
        ]
      },
      "ui": {
        "widget": "objectives_editor",
        "label": "Objectives"
      }
    },
    "flags_set_on_completion": {
      "type": "array",
      "description": "Flags to set when the quest is fully completed",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Flags Set on Completion",
        "reference": "flags"
      }
    },
    "lifecycle": {
      "type": "object",
      "description": "Distinct discovery, assignment, journal, objectives-met, and turn-in semantics.",
      "properties": {
        "assignment_mode": { "type": "string", "enum": ["automatic", "npc_offer", "dialogue_choice", "discovery"], "default": "npc_offer" },
        "initial_journal_state": { "type": "string", "enum": ["hidden", "discovered", "in_journal"], "default": "hidden" },
        "reveal_map_marker": { "type": "boolean", "default": false },
        "turn_in_mode": { "type": "string", "enum": ["automatic", "npc", "location", "none"], "default": "npc" },
        "turn_in_target_id": { "type": "string" }
      }
    },
    "reward_policy": { "type": "object", "properties": { "timing": { "type": "string", "enum": ["on_objectives_met", "on_turn_in", "immediate"], "default": "on_turn_in" }, "target_scope": { "type": "string", "enum": ["player", "party"], "default": "player" } } },
    "repeat_policy": { "type": "string", "enum": ["inherit_owner", "one_shot", "repeatable"], "default": "one_shot", "ui": { "widget": "select", "label": "Repeat Policy" } },
    "xp_reward": {
      "type": "number",
      "description": "XP granted when the quest is completed",
      "ui": {
        "widget": "number",
        "label": "Experience"
      }
    },
    "currency_rewards": {
      "type": "array",
      "description": "Currencies granted on completion",
      "items": {
        "type": "object",
        "properties": {
          "currency_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "currencies",
              "label": "Currency"
            },
            "description": "Currency granted when this quest reward is paid out."
          },
          "amount": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Amount"
            },
            "description": "Amount of the selected currency awarded."
          }
        },
        "required": [
          "currency_id",
          "amount"
        ]
      }
    },
    "reputation_rewards": {
      "type": "array",
      "description": "Faction reputation adjustments",
      "items": {
        "type": "object",
        "properties": {
          "faction_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "factions",
              "label": "Faction"
            },
            "description": "Faction whose reputation changes after this quest."
          },
          "amount": {
            "type": "number",
            "description": "Positive or negative reputation delta",
            "ui": {
              "widget": "number",
              "label": "Delta"
            }
          }
        },
        "required": [
          "faction_id",
          "amount"
        ]
      }
    },
    "item_rewards": {
      "type": "array",
      "description": "Items granted as a reward",
      "items": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "items",
              "label": "Item"
            },
            "description": "Item granted by this quest reward."
          },
          "quantity": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Quantity"
            },
            "description": "Number of copies of the selected item awarded."
          }
        },
        "required": [
          "item_id",
          "quantity"
        ]
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorisation",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug",
    "title",
    "description"
  ]
}
