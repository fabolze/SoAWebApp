{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Requirements",
  "type": "object",
  "description": "Shared logic for unlocking quests, items, events, shops, etc.",
  "properties": {
    "id": {
      "type": "string",
      "ui": {
        "widget": "hidden"
      },
      "description": "Stable unique identifier for this requirement set."
    },
    "slug": {
      "type": "string",
      "ui": {
        "widget": "text",
        "label": "ID/Slug"
      },
      "description": "Readable identifier used when linking this requirement set from content."
    },
    "required_flags": {
      "type": "array",
      "description": "Flags the player must have",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Required Flags"
      }
    },
    "forbidden_flags": {
      "type": "array",
      "description": "Flags that must NOT be set",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "multiselect",
        "label": "Forbidden Flags"
      }
    },
    "min_faction_reputation": {
      "type": "array",
      "description": "Minimum reputation per faction",
      "items": {
        "type": "object",
        "properties": {
          "faction_id": {
            "type": "string",
            "ui": {
              "widget": "reference",
              "reference": "factions"
            },
            "description": "Faction checked by this reputation requirement."
          },
          "min": {
            "type": "number",
            "ui": {
              "widget": "number",
              "label": "Minimum Rep"
            },
            "description": "Minimum reputation value required for the selected faction."
          }
        },
        "required": [
          "faction_id",
          "min"
        ]
      },
      "ui": {
        "widget": "table",
        "label": "Faction Reputation"
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for filtering/searching/categorization",
      "items": {
        "type": "string"
      },
      "ui": {
        "widget": "tags",
        "label": "Tags"
      }
    }
  },
  "required": [
    "id",
    "slug"
  ]
}
