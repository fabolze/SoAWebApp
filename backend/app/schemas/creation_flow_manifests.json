{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Creation Flow Manifest",
  "type": "object",
  "description": "Authoring-only compiler or capture provenance for a committed Creation Flow.",
  "properties": {
    "id": {"type": "string"},
    "slug": {"type": "string"},
    "title": {"type": "string"},
    "format": {"type": "string", "enum": ["SOA-CREATION-FLOW/1"]},
    "revision": {"type": "integer"},
    "shape": {"type": "string", "enum": ["sequence", "constellation", "hybrid"]},
    "compiler_version": {"type": "string"},
    "preview_hash": {"type": "string"},
    "normalized_draft": {"type": "object"},
    "provenance": {"type": "array", "items": {"type": "object"}},
    "accepted_warnings": {"type": "array", "items": {"type": "string"}},
    "canonical_snapshots": {"type": "array", "items": {"type": "object"}},
    "implementation_summary": {"type": "string"},
    "schema_version": {"type": "integer"},
    "origin_kind": {"type": "string"},
    "origin_id": {"type": "string"},
    "origin_sub_kind": {"type": "string"},
    "origin_sub_id": {"type": "string"},
    "accepted_warning_ids": {"type": "array", "items": {"type": "string"}},
    "source_snapshots": {"type": "object"},
    "artifact_dispositions": {"type": "object"},
    "created_at": {"type": "number"},
    "updated_at": {"type": "number"},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["id", "title", "format", "compiler_version", "normalized_draft"]
}
